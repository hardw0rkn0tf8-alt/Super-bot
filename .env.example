# ─── REQUIRED ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# ─── MODULE: VERIFY / WELCOME ─────────────────────────────────────────────────
VERIFIED_ROLE_NAME=Verified
VERIFY_CHANNEL_NAME=get-verify
WELCOME_CHANNEL_NAME=welcome
INVITES_CHANNEL_NAME=invites
INVITES_NEEDED=10

# ─── MODULE: UPDATES BOT ──────────────────────────────────────────────────────
GUILD_ID=your_guild_id_here
BOT_NAME=UH Services
SITE_URL=https://uhservices.gg

# ─── MODULE: ANTI-SCAM BOT ───────────────────────────────────────────────────
